{
  "name": "@albatros/auth-shared",
  "version": "1.0.0",
  "description": "Shared application-level authentication, secrets vault and session sync for Albatros desktop apps (Electron).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist",
    "prerelease": "npm run clean && npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Albatros0626/albatros-auth-shared.git"
  },
  "author": "Albatros0626",
  "license": "UNLICENSED",
  "private": true,
  "peerDependencies": {
    "electron": ">=28.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.6.0",
    "electron": "^28.0.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
